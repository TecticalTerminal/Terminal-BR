# Use PRIVATE KEYs printed by `anvil` startup output.

RPC_URL=http://127.0.0.1:8545
CHAIN_ID_EXPECTED=31337
ALLOW_NON_SEPOLIA=1

# Must be Anvil private keys (not MetaMask main/sepolia keys)
DEPLOYER_PRIVATE_KEY=
OPERATOR_PRIVATE_KEY=

# Optional: if empty, script derives from OPERATOR_PRIVATE_KEY
MARKET_RESOLVER=
# Optional bettors (default fallback: deployer/operator)
BETTOR1_PRIVATE_KEY=
BETTOR2_PRIVATE_KEY=

# Optional scenario controls
GAME_ID=game-anvil-local
OUTCOME_A_LABEL=HUMAN_1
OUTCOME_B_LABEL=AI_1
WINNER_LABEL=HUMAN_1
ROUND_LOCK_SECONDS=45
BET1_VALUE=0.01ether
BET2_VALUE=0.02ether
SKIP_CLAIM=0
