API_HOST=0.0.0.0
API_PORT=8787
DATABASE_URL=postgres://user:password@ep-xxxxx.neon.tech/neondb?sslmode=require

# Market integration (optional)
MARKET_ENABLED=false
MARKET_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
MARKET_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
MARKET_OPERATOR_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
MARKET_ROUND_LOCK_SECONDS=180
MARKET_CHAIN_ID_EXPECTED=11155111

# AI decision provider (rules | openrouter)
AI_PROVIDER=rules
AI_DEBUG=false
AI_TIMEOUT_MS=1200
AI_OPENROUTER_MAX_RETRIES=1
AI_OPENROUTER_RETRY_BASE_DELAY_MS=250
AI_OPENROUTER_COOLDOWN_MS=5000
AI_FALLBACK_RULES=true

# Required when AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional OpenRouter attribution headers
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=

# A2A fixed-price market (M2)
M2_MARKET_CIRCUIT_BREAKER=false
M2_MARKET_DEFAULT_FEE_BPS=300
M2_MARKET_MAX_SINGLE_TRADE_GROSS_CREDITS=100000
M2_MARKET_MAX_TRADES_PER_GAME=20
# Optional comma-separated whitelist. Empty means allow all equipment ids.
M2_EQUIPMENT_WHITELIST=
# Optional protocol fee collector agent id (must be UUID format).
M2_FEE_COLLECTOR_AGENT_ID=00000000-0000-0000-0000-00000000f001
# Autonomous one-shot bot trade defaults (seller->listing->buyer)
M2_AUTO_TRADE_DEFAULT_SELLER_AGENT_ID=
M2_AUTO_TRADE_DEFAULT_BUYER_AGENT_ID=
M2_AUTO_TRADE_DEFAULT_ASSET_ID=demo_blade
M2_AUTO_TRADE_DEFAULT_QUANTITY=1
M2_AUTO_TRADE_DEFAULT_UNIT_PRICE=120
M2_AUTO_TRADE_DEFAULT_FEE_BPS=300
M2_AUTO_TRADE_DEFAULT_MAX_BUY_UNIT_PRICE=150
M2_AUTO_TRADE_DEFAULT_AUTO_SEED=true
M2_AUTO_TRADE_DEFAULT_BUYER_CREDITS_TARGET=2000
M2_AUTO_TRADE_DEFAULT_SELLER_EQUIPMENT_TARGET=1

# ERC-8004 adapter (P+ minimal)
ERC8004_ENABLED=false
ERC8004_RPC_URL=https://sepolia.base.org
ERC8004_IDENTITY_CONTRACT=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
ERC8004_CHAIN_ID_EXPECTED=84532
# Optional base URI for generated agentURI, fallback: https://terminal.local/agents
ERC8004_AGENT_URI_BASE=
ERC8004_DISCOVERY_MAX_SCAN=50
ERC8004_DISCOVERY_CACHE_TTL_SECONDS=3600
ERC8004_DISCOVERY_FETCH_TIMEOUT_MS=4000
ERC8004_IPFS_GATEWAY=https://ipfs.io

# X402 adapter (P+ minimal)
X402_ENABLED=false
X402_MODE=simulated
X402_FACILITATOR_URL=https://facilitator.openx402.ai
# Comma-separated domain whitelist for paid requests
X402_ALLOWED_DOMAINS=conway.tech,localhost,127.0.0.1
X402_MAX_SINGLE_PAYMENT_CENTS=100
X402_BUDGET_CENTS=5000
X402_TIMEOUT_MS=8000
# Optional static payment header payload (base64/json/plain, passed as X-Payment)
X402_STATIC_PAYMENT_TOKEN=
# Optional step24 demo endpoint
X402_DEMO_INTEL_URL=http://localhost:8787/api/x402/provider/intel
X402_DEMO_INTEL_METHOD=POST
